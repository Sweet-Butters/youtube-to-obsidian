vault.example/.obsidian/cache
vault.example/.obsidian/plugins/*/data.json
.trash/

# Secrets — extra defense, never commit these
*credentials*
*secret*
*.key
*.pem
keys.txt
.env.local

# Screenshots / personal credentials — never commit
webshare_*.png
*.screenshot.png
