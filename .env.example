# Copy to .env (or set as GitHub Actions repository secrets) and fill in.
# .env is gitignored — never commit real keys.

# Required
YOUTUBE_API_KEY=<YOUR_YOUTUBE_DATA_API_V3_KEY>
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# Optional fallbacks for the LLM router (auto_project.llm tries Gemini -> Groq -> Cerebras)
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Optional — only if you use auto_project's Telegram bot for phone-triggered runs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
